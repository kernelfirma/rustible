# ║                                                                              ║
# ║   Environment Configuration Template                                         ║
# ║   Copy to .env and customize for your environment                           ║
# ║                                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. CORE CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Path to Rustible configuration file (TOML/YAML/JSON)
# Type: path | Default: searches standard locations
# Locations: /etc/rustible/rustible.cfg, ~/.rustible.cfg, ./rustible.cfg
# RUSTIBLE_CONFIG=/path/to/rustible.cfg

# Rustible home directory for cache and data files
# Type: path | Default: ~/.rustible
# RUSTIBLE_HOME=~/.rustible

# Path to default inventory file or directory
# Type: path | Default: none (must specify with -i flag)
# RUSTIBLE_INVENTORY=./inventory/hosts.yml

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. EXECUTION SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Number of parallel forks for concurrent host execution
# Type: integer | Default: 5 | Range: 1-100+
# RUSTIBLE_FORKS=5

# Default connection timeout in seconds
# Type: integer | Default: 30
# RUSTIBLE_TIMEOUT=30

# Execution strategy: linear, free, or host-pinned
# Type: string | Default: linear
# Options: linear (complete task on all hosts before next task)
#          free (each host proceeds independently)
#          host-pinned (dedicated workers per host)
# RUSTIBLE_STRATEGY=linear

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. SSH CONNECTION SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Default remote user for SSH connections
# Type: string | Default: current user ($USER)
# RUSTIBLE_REMOTE_USER=deploy

# Path to private key file for SSH authentication
# Type: path | Default: ~/.ssh/id_ed25519 or ~/.ssh/id_rsa
# RUSTIBLE_PRIVATE_KEY_FILE=~/.ssh/id_ed25519

# Alias for private key file (alternative variable name)
# Type: path | Default: none
# RUSTIBLE_SSH_KEY=~/.ssh/deploy_key

# Extra SSH arguments (space-separated)
# Type: string | Default: ControlMaster=auto ControlPersist=60s
# RUSTIBLE_SSH_ARGS=-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null

# SSH agent socket path (standard SSH environment variable)
# Type: path | Default: set by ssh-agent
# SSH_AUTH_SOCK=/run/user/1000/ssh-agent.socket

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. PRIVILEGE ESCALATION (BECOME/SUDO)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable privilege escalation by default
# Type: boolean (presence enables) | Default: disabled
# RUSTIBLE_BECOME=true

# Privilege escalation method
# Type: string | Default: sudo
# Options: sudo, su, pbrun, pfexec, doas, dzdo, ksu, runas
# RUSTIBLE_BECOME_METHOD=sudo

# Target user for privilege escalation
# Type: string | Default: root
# RUSTIBLE_BECOME_USER=root

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 5. VAULT ENCRYPTION (RUSTIBLE VAULT)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Path to file containing vault password (one password per line)
# Type: path | Default: none (prompt for password)
# RUSTIBLE_VAULT_PASSWORD_FILE=~/.vault_pass

# Vault password for encrypting/decrypting secrets
# Type: string | Default: none
# WARNING: Avoid using in production; prefer password file
# RUSTIBLE_VAULT_PASSWORD=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6. HASHICORP VAULT INTEGRATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# HashiCorp Vault server address
# Type: url | Default: http://127.0.0.1:8200
# VAULT_ADDR=https://vault.example.com:8200

# Vault authentication token
# Type: string | Default: none
# VAULT_TOKEN=hvs.xxxxxxxxxxxxx

# AppRole authentication (alternative to token)
# Type: string | Default: none
# VAULT_ROLE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VAULT_SECRET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AppRole mount path
# Type: string | Default: approle
# VAULT_APPROLE_MOUNT=approle

# Vault namespace for enterprise deployments
# Type: string | Default: none (root namespace)
# VAULT_NAMESPACE=admin/team-a

# TLS verification and certificates
# Type: boolean (presence enables) | Default: verify enabled
# VAULT_SKIP_VERIFY=true

# Path to CA certificate bundle for TLS verification
# Type: path | Default: system CA bundle
# VAULT_CACERT=/etc/ssl/certs/vault-ca.pem

# Client certificate and key for mutual TLS
# Type: path | Default: none
# VAULT_CLIENT_CERT=/etc/ssl/certs/vault-client.pem
# VAULT_CLIENT_KEY=/etc/ssl/private/vault-client-key.pem

# Vault request timeout in seconds
# Type: integer | Default: 30
# VAULT_TIMEOUT=30

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 7. AWS CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# AWS region for API calls
# Type: string | Default: us-east-1
# Options: us-east-1, us-west-2, eu-west-1, ap-northeast-1, etc.
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# AWS credentials
# Type: string | Default: none (uses credential chain)
# Credential chain: env vars → credentials file → IAM role
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=FwoGZXIvYXdzEBYaDH...

# AWS profile from credentials file
# Type: string | Default: default
# AWS_PROFILE=production

# Path to shared credentials file
# Type: path | Default: ~/.aws/credentials
# AWS_SHARED_CREDENTIALS_FILE=~/.aws/credentials

# AWS endpoint URL for custom endpoints (localstack, minio, etc.)
# Type: url | Default: none (use AWS endpoints)
# AWS_ENDPOINT_URL=http://localhost:4566

# Enable FIPS endpoints for compliance
# Type: boolean | Default: false
# AWS_USE_FIPS_ENDPOINT=false

# Enable dual-stack (IPv4/IPv6) endpoints
# Type: boolean | Default: false
# AWS_USE_DUALSTACK_ENDPOINT=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 8. GCP CONFIGURATION (Google Cloud Platform)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# GCP project ID
# Type: string | Default: none
# GOOGLE_CLOUD_PROJECT=my-project-123456
# GCLOUD_PROJECT=my-project-123456
# GCP_PROJECT=my-project-123456

# Path to service account credentials JSON
# Type: path | Default: none (uses ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 9. KUBERNETES CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Path to kubeconfig file
# Type: path | Default: ~/.kube/config
# KUBECONFIG=~/.kube/config

# Kubernetes context to use (from kubeconfig)
# Type: string | Default: current-context from kubeconfig
# KUBE_CONTEXT=production-cluster

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 10. ANSIBLE COMPATIBILITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Path to Ansible module library (for Python module fallback)
# Type: path | Default: standard Ansible paths
# ANSIBLE_LIBRARY=/usr/share/ansible/plugins/modules

# Path to Ansible collections
# Type: path | Default: ~/.ansible/collections
# ANSIBLE_COLLECTIONS_PATH=~/.ansible/collections

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 11. LOGGING AND OUTPUT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Path to log file
# Type: path | Default: none (stdout only)
# RUSTIBLE_LOG_PATH=/var/log/rustible/rustible.log

# Log level for tracing subscriber
# Type: string | Default: warn (controlled by -v flags)
# Options: trace, debug, info, warn, error
# RUST_LOG=rustible=info,tower_http=debug

# Disable colored output (standard NO_COLOR convention)
# Type: boolean (presence disables) | Default: colors enabled
# NO_COLOR=1

# Rustible-specific color disable
# Type: boolean (presence disables) | Default: colors enabled
# RUSTIBLE_NO_COLOR=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 12. API SERVER (Optional feature: --features api)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API server bind address
# Type: socket address | Default: 127.0.0.1:8080
# RUSTIBLE_API_BIND=0.0.0.0:8080

# JWT secret key for API authentication
# Type: string | Default: insecure default (MUST change in production)
# RUSTIBLE_API_JWT_SECRET=your-secure-random-secret-key-here

# JWT token expiration in seconds
# Type: integer | Default: 3600 (1 hour)
# RUSTIBLE_API_TOKEN_EXPIRATION=3600

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 13. PROVISIONING (Terraform-like infrastructure)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Terraform state backend for import (S3)
# Type: string | Default: none
# TF_STATE_BUCKET=my-terraform-state
# TF_STATE_KEY=production/terraform.tfstate

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 14. DEVELOPMENT AND DEBUGGING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable backtrace for debugging
# Type: string | Default: 0
# Options: 0 (disabled), 1 (enabled), full (with source locations)
# RUST_BACKTRACE=1

# Enable tokio console for async debugging
# Type: boolean | Default: disabled
# TOKIO_CONSOLE=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# QUICK START EXAMPLES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ MINIMAL SETUP (SSH to remote hosts with defaults)                          │
# └────────────────────────────────────────────────────────────────────────────┘
# RUSTIBLE_INVENTORY=./inventory/hosts.yml
# RUSTIBLE_REMOTE_USER=deploy

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ PRODUCTION SETUP (High parallelism, encrypted secrets)                     │
# └────────────────────────────────────────────────────────────────────────────┘
# RUSTIBLE_INVENTORY=./inventory/production
# RUSTIBLE_FORKS=20
# RUSTIBLE_VAULT_PASSWORD_FILE=~/.vault_pass
# RUSTIBLE_BECOME=true
# RUSTIBLE_STRATEGY=free

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ AWS/CLOUD SETUP (EC2 dynamic inventory, Secrets Manager)                   │
# └────────────────────────────────────────────────────────────────────────────┘
# AWS_REGION=us-west-2
# AWS_PROFILE=production
# RUSTIBLE_INVENTORY=./inventory/aws_ec2.yml

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ HASHICORP VAULT INTEGRATION                                                │
# └────────────────────────────────────────────────────────────────────────────┘
